---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Submit · Vybify" description="Submit a vibe-coded project or skill to Vybify.">
  <a href="/" class="eyebrow inline-flex items-center gap-2 mb-12 hover:text-[var(--color-accent)] transition">
    <span aria-hidden="true">←</span> Back to the index
  </a>

  <section class="grid md:grid-cols-12 gap-x-8 gap-y-10">
    <header class="md:col-span-12 pb-8 border-b-2 border-[var(--color-fg)]">
      <p class="eyebrow mb-3">From the editors</p>
      <h1 class="display text-5xl md:text-7xl leading-[0.95]">
        Submit a piece.
      </h1>
      <p class="lede text-xl md:text-2xl mt-4 max-w-2xl">
        Built something with AI tools? Made a skill, MCP server, or rule pack worth sharing? Send it in.
      </p>
    </header>

    <div class="md:col-span-7">
      <p class="label mb-3">By email</p>
      <h2 class="display text-3xl mb-3">The fastest way</h2>
      <p class="mb-4 leading-relaxed">
        Email <a href="mailto:hello@vybify.com?subject=Submission" class="text-[var(--color-accent)] hover:underline italic">hello@vybify.com</a> with:
      </p>
      <ul class="space-y-1.5 list-none pl-0">
        <li class="border-b border-[var(--color-rule)] pb-1.5">— Name + a one-line tagline</li>
        <li class="border-b border-[var(--color-rule)] pb-1.5">— Live URL (or repo if it's a skill)</li>
        <li class="border-b border-[var(--color-rule)] pb-1.5">— GitHub repo (for star ranking — recommended)</li>
        <li class="border-b border-[var(--color-rule)] pb-1.5">— Three to five tags</li>
        <li>— What you built it with (Claude Code, Cursor, v0, etc.)</li>
      </ul>
    </div>

    <div class="md:col-span-5">
      <p class="label mb-3">Or directly</p>
      <h2 class="display text-3xl mb-3">Open a pull request</h2>
      <p class="mb-4 leading-relaxed">
        Add a JSON entry to the <a href="https://github.com/jakemellman/vybify" class="text-[var(--color-accent)] italic hover:underline">repository</a>, in
        <code class="font-mono text-sm bg-[var(--color-surface)] px-1.5 py-0.5 border border-[var(--color-border)]">src/content/projects/</code>
        or
        <code class="font-mono text-sm bg-[var(--color-surface)] px-1.5 py-0.5 border border-[var(--color-border)]">src/content/skills/</code>.
      </p>
      <pre class="text-xs font-mono bg-[var(--color-surface)] border border-[var(--color-border)] p-4 overflow-x-auto leading-relaxed"><code>{`{
  "name": "Your project",
  "tagline": "One short sentence.",
  "url": "https://example.com",
  "github": "owner/repo",
  "author": "You",
  "tags": ["ai", "indie"],
  "builtWith": ["Claude Code"],
  "addedAt": "2026-04-29"
}`}</code></pre>
    </div>
  </section>
</Layout>

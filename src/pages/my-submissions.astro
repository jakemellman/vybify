---
import Layout from '../layouts/Layout.astro';

const user = Astro.locals.user;
if (!user) {
  return Astro.redirect('/login?redirect=/my-submissions');
}

const { data: submissions } = await Astro.locals.supabase
  .from('submissions')
  .select('*')
  .eq('user_id', user.id)
  .order('created_at', { ascending: false });

const statusColors: Record<string, string> = {
  pending: 'bg-yellow-100 text-yellow-800',
  approved: 'bg-green-100 text-green-800',
  rejected: 'bg-red-100 text-red-800',
};

let deleteMsg: string | null = null;

if (Astro.request.method === 'POST') {
  const form = await Astro.request.formData();
  const action = String(form.get('action'));
  const id = String(form.get('id'));

  if (action === 'delete' && id) {
    const { error } = await Astro.locals.supabase
      .from('submissions')
      .delete()
      .eq('id', id)
      .eq('user_id', user.id);

    if (error) {
      deleteMsg = error.message;
    } else {
      return Astro.redirect('/my-submissions');
    }
  }
}
---

<Layout title="My submissions · vybify" description="Your submitted projects and skills on vybify.">
  <a href="/" class="inline-flex items-center gap-1.5 text-sm text-[var(--color-fg-muted)] hover:text-[var(--color-accent)] transition mb-6">
    <span aria-hidden="true">&larr;</span> Back
  </a>

  <section class="max-w-2xl">
    <div class="flex items-center justify-between mb-6">
      <h1 class="text-2xl font-semibold">My submissions</h1>
      <a href="/submit" class="px-4 py-2 rounded-md bg-[var(--color-accent)] text-white text-sm font-medium hover:bg-[var(--color-accent-hover)] transition">
        New submission
      </a>
    </div>

    {deleteMsg && (
      <p class="text-sm text-red-600 mb-4">{deleteMsg}</p>
    )}

    {!submissions || submissions.length === 0 ? (
      <div class="bg-[var(--color-card)] border border-[var(--color-border)] rounded-xl p-8 text-center">
        <p class="text-[var(--color-fg-muted)] mb-4">No submissions yet.</p>
        <a href="/submit" class="text-[var(--color-accent)] hover:underline text-sm font-medium">
          Submit your first project or skill
        </a>
      </div>
    ) : (
      <div class="flex flex-col gap-3">
        {submissions.map((s: any) => (
          <div class="bg-[var(--color-card)] border border-[var(--color-border)] rounded-xl p-4">
            <div class="flex items-start justify-between gap-3">
              <div class="min-w-0">
                <div class="flex items-center gap-2 mb-1">
                  <h2 class="font-semibold text-sm truncate">{s.name}</h2>
                  <span class={`inline-block px-2 py-0.5 rounded-full text-xs font-medium ${statusColors[s.status] || ''}`}>
                    {s.status}
                  </span>
                  <span class="text-xs text-[var(--color-fg-muted)]">{s.type}</span>
                </div>
                <p class="text-sm text-[var(--color-fg-muted)] line-clamp-1">{s.tagline}</p>
                {s.github && (
                  <p class="text-xs text-[var(--color-fg-faint)] mt-1">{s.github}</p>
                )}
                {s.status === 'rejected' && s.reviewer_note && (
                  <p class="text-xs text-red-600 mt-2">Note: {s.reviewer_note}</p>
                )}
              </div>
              {s.status === 'pending' && (
                <form method="POST" class="shrink-0">
                  <input type="hidden" name="action" value="delete" />
                  <input type="hidden" name="id" value={s.id} />
                  <button
                    type="submit"
                    class="text-xs text-[var(--color-fg-muted)] hover:text-red-600 transition px-2 py-1"
                    onclick="return confirm('Delete this submission?')"
                  >
                    Delete
                  </button>
                </form>
              )}
            </div>
            <p class="text-xs text-[var(--color-fg-faint)] mt-2">
              {new Date(s.created_at).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}
            </p>
          </div>
        ))}
      </div>
    )}
  </section>
</Layout>

---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Card from '../../components/Card.astro';
import { withStars } from '../../lib/github';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  const skills = await getCollection('skills');
  const tags = new Set<string>();
  for (const e of [...projects, ...skills]) {
    for (const t of e.data.tags) tags.add(t.toLowerCase());
  }
  return [...tags].map((tag) => ({ params: { tag } }));
}

const { tag } = Astro.params;
const projects = (await withStars(await getCollection('projects'))).map((e) => ({ ...e, _type: 'project' as const }));
const skills = (await withStars(await getCollection('skills'))).map((e) => ({ ...e, _type: 'skill' as const }));

const matches = [...projects, ...skills]
  .filter((e) => e.data.tags.map((t: string) => t.toLowerCase()).includes(tag!))
  .sort((a, b) => (b.stars ?? -1) - (a.stars ?? -1));
---

<Layout title={`#${tag} · Vybify`}>
  <a href="/" class="eyebrow inline-flex items-center gap-2 mb-12 hover:text-[var(--color-accent)] transition">
    <span aria-hidden="true">←</span> Back to the index
  </a>

  <section class="mb-10 pb-8 border-b-2 border-[var(--color-fg)]">
    <p class="eyebrow mb-3">Topic</p>
    <h1 class="display text-6xl md:text-7xl tracking-tight">
      <span class="text-[var(--color-accent)]">#</span>{tag}
    </h1>
    <p class="display-italic text-xl text-[var(--color-fg-muted)] mt-3">
      {matches.length} {matches.length === 1 ? 'entry' : 'entries'} carry this topic.
    </p>
  </section>

  <div>
    {matches.map((entry, i) => (
      <Card
        rank={i + 1}
        name={entry.data.name}
        tagline={entry.data.tagline}
        href={`/${entry._type === 'project' ? 'projects' : 'skills'}/${entry.id}`}
        url={entry.data.url}
        github={entry.data.github}
        author={entry.data.author}
        tags={entry.data.tags}
        stars={entry.stars}
        delta7d={entry.delta7d}
        featured={entry.data.featured}
      />
    ))}
  </div>
</Layout>

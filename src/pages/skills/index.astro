---
import Layout from '../../layouts/Layout.astro';
import SearchableGrid from '../../components/SearchableGrid.astro';
---

<Layout title="Skills · Vybify">
  <section class="mb-10 pb-8 border-b border-[var(--color-border)]">
    <p class="eyebrow mb-3">Section · Skills</p>
    <h1 class="display text-5xl md:text-6xl leading-tight mb-3">
      Skills, MCP servers &amp; rule packs.
    </h1>
    <p class="display-italic text-xl text-[var(--color-fg-muted)] max-w-2xl">
      The things you bolt onto Claude Code, Cursor, and friends.
    </p>
  </section>

  <SearchableGrid type="skill" />
</Layout>

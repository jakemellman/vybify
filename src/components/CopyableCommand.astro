---
interface Props {
  command: string;
  prefix?: string;
  label?: string;
}

const { command, prefix = '$', label } = Astro.props;
---

<div class="vyb-copy group relative bg-[var(--color-fg)] text-[var(--color-paper)]">
  {label && (
    <div class="label text-[var(--color-paper)]/70 px-4 pt-3 pb-1">
      {label}
    </div>
  )}
  <pre class="px-4 pb-4 pr-16 overflow-x-auto"><code class="font-mono text-sm">{prefix && (<span class="text-[var(--color-paper)]/50 select-none mr-2">{prefix}</span>)}<span class="vyb-copy-text">{command}</span></code></pre>
  <button
    type="button"
    class="vyb-copy-btn absolute top-2.5 right-2.5 px-2.5 py-1 text-xs font-mono uppercase tracking-widest border border-[var(--color-paper)]/30 text-[var(--color-paper)]/80 hover:text-[var(--color-paper)] hover:border-[var(--color-paper)] transition"
    aria-label="Copy command"
  >
    Copy
  </button>
</div>

<script>
  document.querySelectorAll<HTMLElement>('.vyb-copy').forEach((wrap) => {
    const btn = wrap.querySelector<HTMLButtonElement>('.vyb-copy-btn');
    const text = wrap.querySelector<HTMLElement>('.vyb-copy-text');
    if (!btn || !text) return;

    btn.addEventListener('click', async () => {
      try {
        await navigator.clipboard.writeText(text.textContent ?? '');
        const original = btn.textContent;
        btn.textContent = 'Copied';
        setTimeout(() => {
          btn.textContent = original;
        }, 1500);
      } catch (err) {
        console.error('Copy failed', err);
      }
    });
  });
</script>

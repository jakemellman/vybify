---
import CardCompact from './CardCompact.astro';

interface Entry {
  _type: 'project' | 'skill';
  _id: string;
  data: any;
  stars: number | null;
  delta7d: number | null;
  badge?: string;
}

interface Props {
  title: string;
  subtitle?: string;
  viewAllHref?: string;
  entries: Entry[];
  layout?: 'single' | 'double';
}

const { title, subtitle, viewAllHref, entries, layout = 'single' } = Astro.props;
---

<section class="mb-10">
  <header class="flex items-baseline justify-between mb-3 px-1">
    <div class="min-w-0">
      <h2 class="text-lg font-semibold text-[var(--color-fg)]">{title}</h2>
      {subtitle && <p class="text-xs text-[var(--color-fg-muted)] mt-0.5">{subtitle}</p>}
    </div>
    {viewAllHref && (
      <a href={viewAllHref} class="text-sm text-[var(--color-accent)] hover:underline shrink-0 ml-3">
        View all →
      </a>
    )}
  </header>

  <div
    class:list={[
      'flex gap-3 overflow-x-auto snap-x pb-2 -mx-4 px-4',
      'scroll-smooth',
      layout === 'double' ? 'grid-rows-2' : '',
    ]}
    style={layout === 'double' ? 'display: grid; grid-template-rows: repeat(2, 1fr); grid-auto-flow: column; grid-auto-columns: max-content; gap: 0.75rem;' : ''}
  >
    {entries.map((e) => {
      const detailHref = `/${e._type === 'project' ? 'projects' : 'skills'}/${e._id.slice(2)}`;
      return (
        <CardCompact
          name={e.data.name}
          tagline={e.data.tagline}
          href={detailHref}
          author={e.data.author}
          stars={e.stars}
          delta7d={e.delta7d}
          badge={e.badge}
          featured={e.data.featured}
        />
      );
    })}
  </div>
</section>

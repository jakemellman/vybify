---
import { formatStars, formatDelta } from '../lib/github';

interface Props {
  rank?: number;
  name: string;
  tagline: string;
  href: string;
  url: string;
  github?: string;
  author?: string;
  tags: string[];
  stars: number | null;
  delta7d?: number | null;
  badge?: string;
  featured?: boolean;
}

const { rank, name, tagline, href, url, github, author, tags, stars, delta7d, badge, featured } = Astro.props;
const deltaLabel = formatDelta(delta7d ?? null);
const starsStr = formatStars(stars);

const toRoman = (n: number): string => {
  const map: [number, string][] = [
    [10, 'X'], [9, 'IX'], [5, 'V'], [4, 'IV'], [1, 'I'],
  ];
  let r = '';
  let v = n;
  for (const [num, ch] of map) {
    while (v >= num) {
      r += ch;
      v -= num;
    }
  }
  return r;
};

const rankLabel = rank !== undefined ? toRoman(rank) : null;
---

<article
  class:list={[
    'vyb-row group relative grid grid-cols-[2.5rem_1fr_auto] sm:grid-cols-[3rem_1fr_auto] gap-x-4 sm:gap-x-6 py-5 border-b border-[var(--color-border)] transition',
    featured ? 'bg-[var(--color-paper)]' : '',
    'hover:bg-[var(--color-paper)]',
  ]}
>
  <a href={href} class="absolute inset-0" aria-label={name}></a>

  <div class="relative pointer-events-none">
    <span class="block label tnum pt-1 leading-none">
      {rankLabel ?? '·'}
    </span>
    {featured && (
      <span class="block label text-[var(--color-accent)] mt-2 leading-none">
        Featured
      </span>
    )}
  </div>

  <div class="relative pointer-events-none min-w-0">
    <div class="flex items-baseline gap-3 flex-wrap">
      <h3 class="display text-2xl md:text-[28px] font-medium leading-tight text-[var(--color-fg)] group-hover:text-[var(--color-accent)] transition">
        {name}
      </h3>
      {badge && (
        <span class="label text-[var(--color-accent-2)]">
          [{badge}]
        </span>
      )}
    </div>

    <p class="mt-1.5 text-base text-[var(--color-fg-soft)] leading-snug max-w-prose">
      {tagline}
    </p>

    <div class="mt-3 flex flex-wrap items-baseline gap-x-4 gap-y-1 text-sm">
      <div class="relative pointer-events-auto flex flex-wrap gap-1.5">
        {tags.slice(0, 4).map((tag) => (
          <a
            href={`/tag/${encodeURIComponent(tag.toLowerCase())}`}
            class="text-[var(--color-fg-muted)] italic hover:text-[var(--color-accent)] transition"
          >
            #{tag}
          </a>
        ))}
      </div>
      {author && (
        <span class="ml-auto text-[var(--color-fg-faint)] italic text-sm pointer-events-none">
          by {author}
        </span>
      )}
    </div>
  </div>

  <div class="relative pointer-events-none flex flex-col items-end justify-start gap-1 text-right">
    <div class="font-mono text-sm tnum text-[var(--color-fg)]">
      {starsStr}
      <span class="text-[var(--color-fg-muted)]">★</span>
    </div>
    {deltaLabel && (
      <div class="font-mono text-xs tnum text-[var(--color-accent-2)]">
        {deltaLabel} 7d
      </div>
    )}
  </div>
</article>
